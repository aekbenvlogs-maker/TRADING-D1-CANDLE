[MASTER]
jobs=1
suggestion-mode=yes
unsafe-load-any-extension=no

[MESSAGES CONTROL]
disable=C0114,C0115,C0116

[REPORTS]
output-format=text
reports=no
score=yes
evaluation=max(0, 0 if fatal else 10.0 - ((float(5 * error + warning + refactor + convention) / statement) * 10))

[FORMAT]
max-line-length=88
indent-string='    '

[DESIGN]
max-args=8
max-attributes=10
max-bool-expr=5
max-branches=12
max-locals=15
max-returns=6
max-statements=50
min-public-methods=1
